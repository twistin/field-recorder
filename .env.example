# Variables locales opcionales para desarrollo.
# Esta app no necesita claves Gemini en cliente.

# Desactiva HMR si tu entorno embebido lo necesita.
DISABLE_HMR="false"

# Token de Vercel Blob para respaldar sesiones y fotos en la nube.
# En producción se configura desde el panel de Vercel al conectar un Blob store.
# Para desarrollo local puedes obtenerlo con `vercel env pull`.
# Si quieres probar las rutas `api/*` en local, usa `vercel dev`.
BLOB_READ_WRITE_TOKEN=""

# Cadena de conexión de Neon Postgres para el catálogo remoto.
# En Vercel puede venir como DATABASE_URL o POSTGRES_URL desde la integración de Neon.
DATABASE_URL=""
POSTGRES_URL=""
